---
import Header from "./Header.astro";
import Hero from "./Hero.astro";
import Footer from "./Footer.astro";
import Carousel from "./Carousel.astro";

const features = [
  {
    icon: "school",
    title: "Learning",
    desc: "Access to IEEE Xplore, magazines, and cutting-edge technical journals.",
    color: "from-teal-500 to-cyan-500",
    glowColor: "teal",
  },
  {
    icon: "groups",
    title: "Networking",
    desc: "Connect with professionals and peers across the globe.",
    color: "from-blue-500 to-indigo-500",
    glowColor: "blue",
  },
  {
    icon: "emoji_events",
    title: "Recognition",
    desc: "Awards, scholarships, competitions, and career opportunities.",
    color: "from-amber-500 to-orange-500",
    glowColor: "amber",
  },
];

const stats = [
  { number: "100+", label: "Active Members", icon: "groups", accent: "border-teal-500" },
  { number: "20+", label: "Annual Events", icon: "event", accent: "border-blue-500" },
  { number: "05+", label: "Workshops", icon: "handyman", accent: "border-amber-500" },
  { number: "10+", label: "Projects", icon: "lightbulb", accent: "border-emerald-500" },
];

const aboutHighlights = [
  { icon: "build", text: "Workshops & Seminars" },
  { icon: "code", text: "Technical Projects" },
  { icon: "business", text: "Industry Visits" },
];
---

<!--
 * Website for IEEE SB CETKR
 * Copyright (C) 2025 IEEE Student Branch CETKR
 -->
<Header />

<main class="relative overflow-hidden bg-slate-950">
  <Hero />

  <!-- Feature Strip -->
  <section class="relative z-[1] -mt-16 pb-24">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-6">
        {
          features.map((item, index) => (
            <div
              class="glass-card border-glow group relative p-8 rounded-2xl transition-all duration-500 hover:-translate-y-2 overflow-hidden"
              data-aos="fade-up"
              data-aos-delay={index * 120}
            >
              <!-- Hover glow background -->
              <div class={`absolute inset-0 bg-gradient-to-br ${item.color} opacity-0 group-hover:opacity-[0.04] transition-opacity duration-500 rounded-2xl`}></div>

              <div class="relative z-10">
                <div class={`w-14 h-14 bg-gradient-to-br ${item.color} rounded-xl flex items-center justify-center mb-5 shadow-lg group-hover:scale-110 group-hover:shadow-${item.glowColor}-500/30 transition-all duration-300`}>
                  <span class="material-icons text-white text-xl" aria-hidden="true">
                    {item.icon}
                  </span>
                </div>
                <h3 class="text-xl font-bold text-white mb-2 group-hover:text-glow transition-all">
                  {item.title}
                </h3>
                <p class="text-slate-400 text-sm leading-relaxed group-hover:text-slate-300 transition-colors">
                  {item.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="relative py-28 overflow-hidden">
    <!-- Decorative Background -->
    <div class="absolute inset-0 dot-grid opacity-40"></div>
    <div
      class="absolute top-1/2 left-0 w-full h-[400px] -translate-y-1/2 bg-gradient-to-r from-teal-900/8 via-blue-900/8 to-transparent -skew-y-2 z-0"
    ></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Carousel Side -->
        <div class="order-2 lg:order-1" data-aos="fade-right" data-aos-duration="1000">
          <div class="relative">
            <!-- Decorative ring -->
            <div class="absolute -inset-8 border border-dashed border-cyan-500/10 rounded-3xl"></div>
            <div
              class="absolute -inset-4 bg-gradient-to-r from-teal-500/10 to-blue-500/10 rounded-2xl blur-xl"
            ></div>
            <div
              class="relative glass-card p-2 rounded-2xl"
            >
              <Carousel />
            </div>
          </div>
        </div>

        <!-- Text Side -->
        <div class="space-y-8 order-1 lg:order-2" data-aos="fade-left" data-aos-duration="1000">
          <div>
            <span
              class="inline-flex items-center text-sm font-bold text-cyan-400 tracking-[0.15em] uppercase mb-3"
            >
              <span class="w-8 h-px bg-cyan-400 mr-3"></span>
              Who We Are
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight">
              Empowering Future <span class="gradient-text">Innovators</span>
            </h2>
          </div>

          <p class="text-slate-300 leading-relaxed text-lg">
            The IEEE Student Branch at College of Engineering Trikaripur is a
            dynamic community of students passionate about technology,
            innovation, and professional development. We provide a platform for
            students to enhance their technical skills, network with industry
            professionals, and work on cutting-edge projects.
          </p>

          <!-- Highlight Badges -->
          <div class="flex flex-wrap gap-3">
            {aboutHighlights.map((item) => (
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-800/60 border border-white/5 text-slate-300 text-sm font-medium hover:border-cyan-500/20 hover:bg-cyan-950/30 transition-all duration-300">
                <span class="material-icons text-cyan-400 text-base" aria-hidden="true">{item.icon}</span>
                {item.text}
              </span>
            ))}
          </div>

          <div class="pt-2">
            <a
              href="/contact"
              class="inline-flex items-center text-white font-medium hover:text-cyan-400 transition-colors group"
            >
              Get in touch with us
              <span class="material-icons ml-2 text-sm group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-28 relative overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-30"></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="inline-flex items-center text-sm font-bold text-cyan-400 tracking-[0.15em] uppercase mb-3">
          <span class="w-8 h-px bg-cyan-400 mr-3"></span>
          Impact
          <span class="w-8 h-px bg-cyan-400 ml-3"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Our Impact in Numbers
        </h2>
        <p class="text-slate-400 max-w-lg mx-auto">
          Growing steadily and creating opportunities for every student.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {
          stats.map((stat, index) => (
            <div
              class={`group relative p-8 glass-card rounded-2xl border-t-2 ${stat.accent} text-center hover:-translate-y-2 transition-all duration-500`}
              data-aos="fade-up"
              data-aos-delay={index * 100}
            >
              <!-- Hover radial glow -->
              <div class="absolute inset-0 rounded-2xl bg-gradient-radial from-white/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

              <div class="relative z-10">
                <div class="mb-4 inline-flex p-3 rounded-xl bg-slate-800/50 text-cyan-400 group-hover:text-white group-hover:bg-gradient-to-br group-hover:from-teal-500 group-hover:to-blue-500 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-teal-500/20">
                  <span class="material-icons text-2xl" aria-hidden="true">
                    {stat.icon}
                  </span>
                </div>

                <div class="text-4xl md:text-5xl font-black text-white mb-2 tracking-tight stat-number" data-target={stat.number}>
                  {stat.number}
                </div>
                <div class="text-slate-500 text-xs font-semibold uppercase tracking-[0.15em] group-hover:text-slate-300 transition-colors">
                  {stat.label}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-28 overflow-hidden">
    <!-- Background mesh -->
    <div class="absolute inset-0 bg-gradient-to-br from-teal-950/40 via-slate-950 to-blue-950/40"></div>
    <div class="absolute inset-0 dot-grid opacity-50"></div>

    <!-- Decorative orbs -->
    <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] bg-teal-500/8 rounded-full blur-[100px]" style="animation: drift 20s ease-in-out infinite;"></div>
    <div class="absolute bottom-[-20%] left-[-10%] w-[400px] h-[400px] bg-blue-500/8 rounded-full blur-[100px]" style="animation: drift 25s ease-in-out infinite reverse;"></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <!-- Floating IEEE Badge -->
        <div class="mb-8 inline-flex">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-500 to-blue-600 flex items-center justify-center shadow-xl shadow-teal-500/20" style="animation: float-slow 4s ease-in-out infinite;">
            <img src="/SB_LOGO_W.png" alt="" class="w-10 h-10 object-contain" aria-hidden="true" />
          </div>
        </div>

        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Ready to <span class="gradient-text">Innovate</span>?
        </h2>
        <p class="text-slate-400 text-lg mb-10 max-w-xl mx-auto">
          Join a global network of 400,000+ members. Access resources, mentorship, and opportunities to shape the future of technology.
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-5">
          <a
            href="https://www.ieee.org/membership/join"
            class="px-8 py-4 bg-gradient-to-r from-teal-500 to-blue-600 text-white font-bold rounded-full shadow-lg shadow-teal-500/20 hover:shadow-teal-500/40 transition-all duration-300 hover:-translate-y-1 shimmer"
          >
            <span class="relative z-10 flex items-center tracking-wide">
              JOIN IEEE TODAY
              <span class="material-icons ml-2 text-lg" aria-hidden="true">arrow_forward</span>
            </span>
          </a>

          <a
            href="/contact"
            class="px-8 py-4 rounded-full font-medium text-white border border-white/15 bg-white/5 backdrop-blur-sm hover:bg-white/10 hover:border-white/25 transition-all duration-300"
          >
            CONTACT US
          </a>
        </div>
      </div>
    </div>
  </section>
</main>

<Footer />
