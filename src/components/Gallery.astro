---
import { Image } from "astro:assets";
import Lightbox from "./shared/Lightbox.astro";

interface GalleryItem {
  type: "image" | "video";
  url: string;
  alt?: string;
  caption?: string;
  thumbnail?: string;
}

interface Props {
  items: GalleryItem[];
  class?: string;
}

const { items = [], class: className = "" } = Astro.props;
const galleryId = `gallery ${Math.random().toString(36).slice(2, 9)}`;
---

<section id={galleryId} class:list={["w-full", className]}>
  <div class="columns-1 sm:columns-2 md:columns-3 gap-4 space-y-4">
    {
      items.map((item, index) => (
        <a
          href={item.url}
          data-type={item.type}
          data-caption={item.caption || ""}
          data-index={index}
          class="gallery-trigger group relative block break-inside-avoid rounded-xl overflow-hidden bg-slate-900 border border-white/5 shadow-md hover:shadow-cyan-500/10 transition-transform duration-300 hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-cyan-500"
          aria-label={`View ${item.type}: ${item.caption || item.alt || "Gallery item"}`}
        >
          <div class="relative overflow-hidden aspect-auto">
            {item.type === "image" ? (
              <Image
                src={item.url}
                alt={item.alt || ""}
                class="w-full h-auto object-cover transform transition-transform duration-700 will-change-transform group-hover:scale-105"
                loading={index < 4 ? "eager" : "lazy"}
                decoding="async"
                width={600}
                height={400}
              />
            ) : (
              <div class="relative w-full">
                {item.thumbnail ? (
                  <img
                    src={item.thumbnail}
                    class="w-full h-auto object-cover opacity-80 group-hover:opacity-60 transition-opacity"
                    loading="lazy"
                    alt="Video thumbnail"
                  />
                ) : (
                  <video
                    src={item.url}
                    class="w-full h-auto object-cover opacity-80 group-hover:opacity-60 transition-opacity"
                    muted
                    preload="metadata"
                    playsinline
                  />
                )}
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center border border-white/30 group-hover:scale-110 group-hover:bg-white/30 transition-all duration-300">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="w-6 h-6 text-white"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            )}

            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />

            {item.caption && (
              <div class="absolute bottom-0 left-0 w-full p-4 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                <p class="text-white text-sm font-medium leading-tight drop-shadow-md line-clamp-2">
                  {item.caption}
                </p>
              </div>
            )}
          </div>
        </a>
      ))
    }
  </div>

  <Lightbox id={`lb-${galleryId}`} />
</section>

<script is:inline define:vars={{ galleryId }}>
  (() => {
    const gallery = document.getElementById(galleryId);
    if (!gallery) return;

    const lightbox = document.getElementById(`lb-${galleryId}`);
    const triggers = gallery.querySelectorAll(".gallery-trigger");
    const items = Array.from(triggers).map(el => ({
      type: el.dataset.type,
      url: el.getAttribute("href"),
      caption: el.dataset.caption
    }));

    triggers.forEach((el, index) => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        if (lightbox && typeof lightbox.open === 'function') {
          lightbox.open(items, index);
        }
      });
    });
  })();
</script>
