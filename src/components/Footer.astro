const socialLinks = [
  { name: "Facebook", url: "https://facebook.com/ieeesbcetkr", icon: ICONS.facebook },
  { name: "Twitter", url: "https://x.com/ieeesbcetkr", icon: ICONS.twitter },
  { name: "LinkedIn", url: "https://linkedin.com/company/ieeesbcetkr", icon: ICONS.linkedin },
  { name: "Instagram", url: "https://instagram.com/ieeesbcetkr", icon: ICONS.instagram },
  { name: "YouTube", url: "https://youtube.com/ieeesbcetkr", icon: ICONS.youtube },
];
---

<footer class="relative bg-slate-950 pt-px">
  <!-- Gradient top border -->
  <div class="w-full h-px bg-gradient-to-r from-transparent via-teal-500/50 to-transparent"></div>

  <div class="pt-16 pb-8">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12 mb-12">
        <!-- Brand Column -->
        <div class="md:col-span-5">
          <a href="/" class="flex items-center gap-3 mb-5 w-fit group">
            <img
              src="/SB_LOGO_W.png"
              alt="IEEE SB CETKR logo"
              class="w-11 h-11 object-contain transition-transform group-hover:scale-105"
              loading="lazy"
            />
            <h3 class="text-xl font-bold text-white">
              <span class="text-cyan-400">IEEE</span> SB CETKR
            </h3>
          </a>
          <p class="text-slate-500 mb-6 max-w-sm text-sm leading-relaxed">
            Empowering the next generation of engineers and technologists through
            innovation, collaboration, and professional development.
          </p>

          <div class="flex space-x-3">
            {
              socialLinks.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.name}
                  class="w-9 h-9 rounded-lg bg-slate-800/60 hover:bg-teal-500/10 text-slate-500 hover:text-cyan-400 flex items-center justify-center transition-all duration-300 hover:scale-110 hover:-translate-y-0.5 border border-transparent hover:border-cyan-500/20"
                >
                  <svg
                    class="w-4 h-4"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    {social.name === "Instagram" ? (
                      <path
                        fill-rule="evenodd"
                        d={social.icon}
                        clip-rule="evenodd"
                      />
                    ) : (
                      <path d={social.icon} />
                    )}
                  </svg>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Quick Links -->
        <div class="md:col-span-3">
          <h4 class="text-sm font-semibold text-white mb-5 tracking-wider uppercase">Quick Links</h4>
          <nav>
            <ul class="space-y-2.5">
              {
                siteLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-slate-500 hover:text-cyan-400 transition-colors duration-300 flex items-center group text-sm"
                    >
                      <span class="w-1 h-1 rounded-full bg-slate-700 mr-2.5 group-hover:bg-cyan-400 group-hover:shadow-[0_0_4px_rgba(34,211,238,0.4)] transition-all" />
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>

        <!-- Contact -->
        <div class="md:col-span-4">
          <h4 class="text-sm font-semibold text-white mb-5 tracking-wider uppercase">Contact Us</h4>
          <address class="not-italic">
            <ul class="space-y-4 text-slate-500 text-sm">
              <li class="flex items-start space-x-3">
                <svg
                  class="w-4 h-4 text-cyan-400/70 mt-0.5 shrink-0"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d={ICONS.location}></path>
                </svg>
                <span class="sr-only">Location:</span>
                <span>College of Engineering Trikaripur, Kasaragod, Kerala, India</span>
              </li>
              <li class="flex items-center space-x-3">
                <svg
                  class="w-4 h-4 text-cyan-400/70 shrink-0"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d={ICONS.email}></path>
                </svg>
                <span class="sr-only">Email:</span>
                <a
                  href="mailto:ieeesbcetkr@gmail.com"
                  class="hover:text-cyan-400 transition-colors duration-300"
                >
                  ieeesbcetkr@gmail.com
                </a>
              </li>
            </ul>
          </address>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-slate-800/60 pt-6 mt-6">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-slate-600 text-xs text-center md:text-left">
            &copy; <time datetime={String(currentYear)}>{currentYear}</time> IEEE Student
            Branch, College of Engineering Trikaripur. All rights reserved.
          </p>
          <div class="flex items-center space-x-6">
            <a
              href="#"
              class="text-slate-600 hover:text-cyan-400 text-xs transition-colors duration-300"
            >Privacy Policy</a>
            <a
              href="#"
              class="text-slate-600 hover:text-cyan-400 text-xs transition-colors duration-300"
            >Terms</a>

            <!-- Back to top -->
            <button
              id="back-to-top"
              class="w-8 h-8 rounded-lg bg-slate-800/60 text-slate-500 hover:text-cyan-400 hover:bg-teal-500/10 flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5 border border-transparent hover:border-cyan-500/20"
              aria-label="Back to top"
            >
              <span class="material-icons text-base" aria-hidden="true">keyboard_arrow_up</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById("back-to-top")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
