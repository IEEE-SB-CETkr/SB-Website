---
import "../styles/components/hero.css";

interface Props {
  // Currently no props, but good for future extensibility
}
---

<!--
 * Website for IEEE SB CETKR
 * Copyright (C) 2025 IEEE Student Branch CETKR
 -->
<section
  class="relative min-h-screen flex items-center justify-center px-4 overflow-hidden bg-slate-950"
  id="hero-section"
>
  <!-- Background Layers -->
  <div class="absolute inset-0 z-0">
    <!-- Primary gradient orbs -->
    <div
      class="absolute top-[-10%] left-[-5%] w-[700px] h-[700px] bg-teal-500/15 rounded-full blur-[140px]"
      style="animation: drift 20s ease-in-out infinite;"
    ></div>
    <div
      class="absolute bottom-[-15%] right-[-10%] w-[600px] h-[600px] bg-blue-600/12 rounded-full blur-[120px]"
      style="animation: drift 25s ease-in-out infinite reverse;"
    ></div>
    <div
      class="absolute top-[40%] left-[50%] w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-[100px]"
      style="animation: float 18s ease-in-out infinite;"
    ></div>

    <!-- Dot grid overlay -->
    <div class="absolute inset-0 dot-grid opacity-60"></div>

    <!-- Floating particles -->
    <div class="particle particle-sm bg-cyan-400/30" style="top: 15%; left: 10%; animation: float 8s ease-in-out infinite;"></div>
    <div class="particle particle-md bg-blue-400/20" style="top: 25%; right: 15%; animation: float 12s ease-in-out infinite 2s;"></div>
    <div class="particle particle-sm bg-teal-300/25" style="top: 60%; left: 20%; animation: float 10s ease-in-out infinite 1s;"></div>
    <div class="particle particle-lg particle-ring text-cyan-400/15" style="top: 30%; left: 60%; animation: drift 15s ease-in-out infinite;"></div>
    <div class="particle particle-md bg-amber-400/15" style="top: 70%; right: 25%; animation: float 14s ease-in-out infinite 3s;"></div>
    <div class="particle particle-sm particle-square bg-blue-300/20" style="top: 45%; left: 35%; animation: drift 11s ease-in-out infinite 1.5s;"></div>
    <div class="particle particle-sm bg-teal-400/20" style="top: 80%; left: 70%; animation: float 9s ease-in-out infinite 4s;"></div>
    <div class="particle particle-lg particle-ring text-amber-400/10" style="top: 20%; right: 40%; animation: drift 18s ease-in-out infinite 2s;"></div>
    <div class="particle particle-md particle-square bg-cyan-300/10" style="bottom: 25%; left: 45%; animation: float 13s ease-in-out infinite 5s;"></div>
    <div class="particle particle-sm bg-blue-400/25" style="bottom: 35%; right: 10%; animation: drift 10s ease-in-out infinite 3s;"></div>
  </div>

  <div class="container mx-auto text-center relative z-10 max-w-5xl px-6">
    <!-- Badge -->
    <div class="mb-10 hero-text-reveal" style="animation-delay: 0.1s;">
      <span
        class="inline-flex items-center px-4 py-1.5 rounded-full border border-cyan-500/20 bg-cyan-950/40 text-cyan-300 text-xs font-bold tracking-[0.2em] uppercase backdrop-blur-xl"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 mr-2.5 badge-dot"></span>
        IEEE Student Branch · CETKR
      </span>
    </div>

    <!-- Main Heading -->
    <h1
      class="text-6xl md:text-8xl lg:text-9xl font-black mb-10 leading-[0.9] tracking-tighter"
    >
      <span class="hero-text-reveal block text-white text-glow" style="animation-delay: 0.3s;">
        INNOVATE
      </span>
      <span class="hero-text-reveal block text-outline my-2 md:my-3" style="animation-delay: 0.5s;">
        INSPIRE
      </span>
      <span class="hero-text-reveal block gradient-text" style="animation-delay: 0.7s;">
        IGNITE
      </span>
    </h1>

    <p
      class="text-base md:text-xl text-slate-400 mb-12 max-w-2xl mx-auto leading-relaxed font-light hero-text-reveal"
      style="animation-delay: 0.9s;"
    >
      Where tomorrow's engineers build today's breakthroughs.
      <span class="text-cyan-400 font-medium">Shape the future</span> with us at
      College of Engineering Trikaripur.
    </p>

    <!-- Buttons -->
    <div
      class="flex flex-col sm:flex-row justify-center items-center gap-5 hero-text-reveal"
      style="animation-delay: 1.1s;"
    >
      <a
        href="https://www.ieee.org/membership/join"
        class="group relative px-8 py-4 bg-gradient-to-r from-teal-500 to-blue-600 text-white font-bold rounded-full shadow-lg shadow-teal-500/20 hover:shadow-teal-500/40 transition-all duration-300 hover:-translate-y-1 shimmer"
      >
        <span class="relative z-10 flex items-center tracking-wide">
          BECOME A MEMBER
          <span
            class="material-icons ml-2 text-lg group-hover:translate-x-1 transition-transform"
            aria-hidden="true">arrow_forward</span>
        </span>
      </a>

      <a
        href="/events"
        class="group px-8 py-4 rounded-full font-medium text-white border border-white/15 bg-white/5 backdrop-blur-sm hover:bg-white/10 hover:border-white/25 transition-all duration-300 tracking-wide"
      >
        <span class="flex items-center">
          SEE OUR WORKS
          <span
            class="material-icons ml-2 text-base opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"
            aria-hidden="true">east</span>
        </span>
      </a>
    </div>
  </div>

</section>
