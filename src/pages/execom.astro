---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MemberCard from "../components/MemberCard.astro";
import { execomMembers } from "../data/execom";
import type { ExecomMember } from "../data/execom";

const title = "Executive Committee | IEEE SB CETKR";
const description =
  "Meet the dedicated team behind IEEE Student Branch at College of Engineering Trikarpur";

const getMembers = (roles: string[]) =>
  roles.flatMap((role) => execomMembers[role] || []);

const facultyMembers = getMembers(["facultyMembers"]);

const leadership = getMembers([
  "Chairperson",
  "Vice Chairperson",
  "Secretary",
  "Joint Secretary",
  "Treasurer",
]);

const WomenInEngineering = getMembers([
  "IEEE WIE Chair",
  "IEEE WIE Vice Chair",
  "IEEE WIE Secretary",
]);

const PowerAndEnergySociety = getMembers([
  "IEEE PES Chair",
  "IEEE PES Vice Chair",
  "IEEE PES Secretary",
  "Women in Power",
  "IEEE PES MDC",
]);
const IndustryApplicationsSociety = getMembers([
  "IEEE IAS Chair",
  "IEEE IAS Vice Chair",
  "IEEE IAS MDC",
]);
const webmasters = getMembers(["Webmasters"]);
const eventCoordinators = getMembers(["Event Coordinators"]);
const LinkRepresentatives = getMembers(["IEEE Link Representative"]);
const designTeam = getMembers(["Design Lead"]);
const contentTeam = getMembers(["Content Lead"]);
const newsletterEditors = getMembers(["Newsletter Editors"]);
const MDC = getMembers(["MDC"]);
const ECC = getMembers(["ECC"]);
const sections = [
  {
    title: "Faculty Advisors",
    color: "from-teal-500 to-cyan-500",
    accentClass: "bg-teal-500",
    members: facultyMembers,
  },
  {
    title: "Leadership",
    color: "from-teal-500 to-cyan-500",
    accentClass: "bg-teal-500",
    members: leadership,
  },
  {
    title: "Webmasters",
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    members: webmasters,
  },
  {
    title: "Event Coordinators",
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    members: eventCoordinators,
  },
  {
    title: "IEEE Link Representatives",
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    members: LinkRepresentatives,
  },
  {
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    isPaired: true,
    mdcMembers: MDC,
    eccMembers: ECC,
  },
  {
    title: "Design Team",
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    members: designTeam,
  },
  {
    title: "Content Team",
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    members: contentTeam,
  },
  {
    title: "Newsletter Editors",
    color: "from-blue-500 to-indigo-500",
    accentClass: "bg-blue-500",
    members: newsletterEditors,
  },
  {
    title: "Power & Energy Society",
    color: "from-amber-500 to-orange-500",
    accentClass: "bg-amber-500",
    members: PowerAndEnergySociety,
  },
  {
    title: "Industry Applications Society",
    color: "from-amber-500 to-orange-500",
    accentClass: "bg-amber-500",
    members: IndustryApplicationsSociety,
  },
  {
    title: "Women in Engineering",
    color: "from-amber-500 to-orange-500",
    accentClass: "bg-amber-500",
    members: WomenInEngineering,
  },
];
---

<Header />
<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="relative pt-40 pb-20 overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-40"></div>
    <div
      class="absolute top-0 right-[10%] w-[500px] h-[500px] bg-teal-500/8 rounded-full blur-[120px]"
      style="animation: drift 20s ease-in-out infinite;"
    >
    </div>
    <div
      class="absolute bottom-0 left-[10%] w-[400px] h-[400px] bg-blue-600/8 rounded-full blur-[100px]"
      style="animation: drift 25s ease-in-out infinite reverse;"
    >
    </div>

    <div class="container mx-auto px-6 relative z-10 text-center">
      <div data-aos="fade-down" data-aos-duration="1000">
        <span
          class="inline-flex items-center px-4 py-1.5 rounded-full border border-cyan-500/20 bg-cyan-950/40 text-cyan-300 text-xs font-bold tracking-[0.15em] uppercase backdrop-blur-xl mb-6"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 mr-2.5"></span>
          Our Team
        </span>
      </div>

      <h1
        class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight"
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="100"
      >
        Executive <span class="gradient-text font-extrabold">Committee</span>
      </h1>

      <p
        class="text-base md:text-xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed"
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="200"
      >
        The passionate leaders and visionaries driving innovation, fostering
        technical excellence, and building a vibrant community at IEEE SB CETKR.
      </p>
    </div>
  </section>

  <!-- Team Sections -->
  <div class="relative pb-20">
    <div class="absolute inset-0 dot-grid opacity-20"></div>

    <div class="container mx-auto px-6 space-y-24 relative z-10">
      {
        sections.map((section) => (
          <section class="relative">
            {!section.isPaired && (
              <div
                class="flex items-center justify-center mb-12"
                data-aos="fade-up"
              >
                <div class="flex items-center gap-4">
                  <span
                    class={`w-10 h-1 ${section.accentClass} rounded-full`}
                  />
                  <h2 class="text-2xl md:text-3xl font-bold text-white">
                    {section.title}
                  </h2>
                  <span
                    class={`w-10 h-1 ${section.accentClass} rounded-full`}
                  />
                </div>
              </div>
            )}

            {section.isPaired ? (
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2">
                  <div
                    class="flex items-center justify-center mb-12"
                    data-aos="fade-up"
                  >
                    <div class="flex items-center gap-4">
                      <span
                        class={`w-10 h-1 ${section.accentClass} rounded-full`}
                      />
                      <h2 class="text-2xl md:text-3xl font-bold text-white">
                        MDC
                      </h2>
                      <span
                        class={`w-10 h-1 ${section.accentClass} rounded-full`}
                      />
                    </div>
                  </div>

                  <div class="p-4 rounded-2xl bg-slate-900/30">
                    <div class="flex flex-wrap justify-center gap-8">
                      {section.mdcMembers.map(
                        (member: ExecomMember, i: number) => (
                          <div
                            class="w-full sm:w-1/2 lg:w-full max-w-sm h-full"
                            data-aos="fade-up"
                            data-aos-delay={i * 80}
                          >
                            <MemberCard member={member} />
                          </div>
                        ),
                      )}
                    </div>
                  </div>
                </div>

                <div class="lg:col-span-1">
                  <div
                    class="flex items-center justify-center mb-12"
                    data-aos="fade-up"
                  >
                    <div class="flex items-center gap-4">
                      <span
                        class={`w-10 h-1 ${section.accentClass} rounded-full`}
                      />
                      <h2 class="text-2xl md:text-3xl font-bold text-white">
                        ECC
                      </h2>
                      <span
                        class={`w-10 h-1 ${section.accentClass} rounded-full`}
                      />
                    </div>
                  </div>

                  <div class="flex flex-col gap-8">
                    <div class="p-4 rounded-2xl bg-slate-900/30">
                      <div class="flex flex-wrap justify-center gap-8">
                        {section.eccMembers
                          .slice(0, 1)
                          .map((member: ExecomMember, i: number) => (
                            <div
                              class="w-full max-w-sm h-full"
                              data-aos="fade-up"
                              data-aos-delay={i * 80}
                            >
                              <MemberCard member={member} />
                            </div>
                          ))}
                      </div>
                    </div>

                    <div class="p-4 rounded-2xl bg-slate-900/30">
                      <div class="flex flex-wrap justify-center gap-8">
                        {section.eccMembers
                          .slice(1)
                          .map((member: ExecomMember, i: number) => (
                            <div
                              class="w-full max-w-sm h-full"
                              data-aos="fade-up"
                              data-aos-delay={i * 80}
                            >
                              <MemberCard member={member} />
                            </div>
                          ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <div class="flex flex-wrap justify-center gap-8">
                {(section.members || []).map((member, i) => (
                  <div
                    class="w-full sm:w-1/2 lg:w-1/3 max-w-sm h-full"
                    data-aos="fade-up"
                    data-aos-delay={i * 80}
                  >
                    <MemberCard member={member} />
                  </div>
                ))}
              </div>
            )}
          </section>
        ))
      }
    </div>
  </div>

  <Footer />
</Layout>
