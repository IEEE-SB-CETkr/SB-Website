---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const allNewsletters = await getCollection("newsletters");
const sortedNewsletters = allNewsletters.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const pageTitle = "Newsletters | IEEE SB CETKR";
const pageDescription =
  "Stay updated with the latest news and updates from IEEE SB CETKR";
---

<Header />
<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen relative z-10">
    <!-- Hero -->
    <section class="relative pt-40 pb-20 overflow-hidden">
      <div class="absolute inset-0 dot-grid opacity-40"></div>
      <div
        class="absolute top-0 right-[10%] w-[500px] h-[500px] bg-teal-500/8 rounded-full blur-[120px]"
        style="animation: drift 20s ease-in-out infinite;"
      ></div>
      <div
        class="absolute bottom-0 left-[10%] w-[400px] h-[400px] bg-blue-600/8 rounded-full blur-[100px]"
        style="animation: drift 25s ease-in-out infinite reverse;"
      ></div>

      <div class="container mx-auto px-6 relative z-10 text-center">
        <div data-aos="fade-down" data-aos-duration="1000">
          <span
            class="inline-flex items-center px-4 py-1.5 rounded-full border border-cyan-500/20 bg-cyan-950/40 text-cyan-300 text-xs font-bold tracking-[0.15em] uppercase backdrop-blur-xl mb-6"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 mr-2.5"></span>
            Stay Updated
          </span>
        </div>

        <h1
          class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
        >
          Our <span class="gradient-text font-extrabold">Newsletters</span>
        </h1>

        <p
          class="text-base md:text-xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          Stay updated with our latest news, events, and technical insights from
          the IEEE Student Branch at College of Engineering Trikaripur.
        </p>
      </div>
    </section>

    <!-- Newsletters Grid -->
    <section class="py-16 relative">
      <div class="absolute inset-0 dot-grid opacity-15"></div>

      <div class="container mx-auto px-6 max-w-7xl relative z-10">
        {
          sortedNewsletters.length > 0 ? (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              {sortedNewsletters.map((newsletter, i) => (
                <article
                  class="group glass-card rounded-2xl overflow-hidden transition-all duration-500 h-full flex flex-col hover:-translate-y-2 hover:shadow-2xl hover:shadow-teal-900/10"
                  data-aos="fade-up"
                  data-aos-delay={i * 100}
                >
                  <a
                    href={`/newsletters/${newsletter.slug}/`}
                    class="block h-full flex flex-col"
                  >
                    {newsletter.data.image ? (
                      <div class="h-56 overflow-hidden relative">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent opacity-60 z-10" />
                        <img
                          src={newsletter.data.image.url}
                          alt={newsletter.data.image.alt || newsletter.data.title}
                          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                          loading="lazy"
                          width={400}
                          height={225}
                        />
                      </div>
                    ) : (
                      <div class="h-56 bg-slate-800/30 flex items-center justify-center relative overflow-hidden group-hover:bg-slate-800/50 transition-colors">
                        <div class="absolute inset-0 bg-gradient-to-br from-teal-500/5 to-blue-500/5" />
                        <span class="material-icons text-5xl text-slate-700 group-hover:scale-110 transition-transform duration-500">
                          newspaper
                        </span>
                      </div>
                    )}

                    <div class="p-8 flex-1 flex flex-col relative z-20">
                      <div class="flex-1">
                        <time class="inline-block px-3 py-1 mb-4 text-xs font-bold text-cyan-400 bg-cyan-950/30 border border-cyan-500/20 rounded-full">
                          {newsletter.data.pubDate.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "short",
                            day: "numeric",
                          })}
                        </time>
                        <h2 class="text-xl font-bold mb-3 text-white group-hover:text-cyan-400 transition-colors leading-tight">
                          {newsletter.data.title}
                        </h2>
                        {newsletter.data.description && (
                          <p class="text-slate-400 text-sm line-clamp-3 leading-relaxed mb-6">
                            {newsletter.data.description}
                          </p>
                        )}
                      </div>

                      <div class="pt-5 mt-auto border-t border-white/5 flex items-center justify-between">
                        <span class="inline-flex items-center text-cyan-400 text-sm font-bold group-hover:translate-x-2 transition-transform duration-300">
                          Read Newsletter
                          <span class="material-icons text-base ml-2">arrow_forward</span>
                        </span>
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <div class="text-center py-24 glass-card rounded-2xl">
              <div class="w-20 h-20 bg-slate-800/50 rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-icons text-4xl text-slate-600">mail_outline</span>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2">
                No newsletters yet
              </h3>
              <p class="text-slate-400 max-w-md mx-auto mb-8">
                We're working on some exciting content. Check back soon for
                updates!
              </p>
              <a
                href="/"
                class="inline-flex items-center px-8 py-3 rounded-full bg-gradient-to-r from-teal-500 to-blue-600 text-white font-semibold transition-all shadow-lg hover:shadow-teal-500/25 hover:-translate-y-0.5"
              >
                <span class="material-icons text-base mr-2">home</span>
                Back to Home
              </a>
            </div>
          )
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>
