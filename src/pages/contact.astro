---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/components/pages.css";

const contactInfo = {
  email: "ieeesbcetkr@gmail.com",
  address: {
    line1: "College of Engineering Trikarpur",
    line2: "Checkidapu, Kasaragod",
    state: "Kerala",
    country: "India",
    pincode: "671320",
  },
  phone: "+91 12345 67890",
  googleMapsUrl: "https://maps.app.goo.gl/vzdU5HfJhyX7hZwo7",
};

const title = "Contact Us | IEEE SB CETKR";
const description =
  "Get in touch with IEEE Student Branch at College of Engineering Trikarpur. We'd love to hear from you!";
---

<!--
 * Website for IEEE SB CETKR
 * Copyright (C) 2025 IEEE Student Branch CETKR
 -->
<Header />
<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="relative pt-40 pb-20 overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-40"></div>
    <div
      class="absolute top-0 right-[15%] w-[500px] h-[500px] bg-teal-500/8 rounded-full blur-[120px]"
      style="animation: drift 20s ease-in-out infinite;"
    ></div>
    <div
      class="absolute bottom-0 left-[10%] w-[400px] h-[400px] bg-blue-600/8 rounded-full blur-[100px]"
      style="animation: drift 25s ease-in-out infinite reverse;"
    ></div>

    <div class="container mx-auto px-6 relative z-10 text-center">
      <div data-aos="fade-down" data-aos-duration="1000">
        <span
          class="inline-flex items-center px-4 py-1.5 rounded-full border border-cyan-500/20 bg-cyan-950/40 text-cyan-300 text-xs font-bold tracking-[0.15em] uppercase backdrop-blur-xl mb-6"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 mr-2.5"></span>
          Get in Touch
        </span>
      </div>

      <h1
        class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight"
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="100"
      >
        Contact <span class="gradient-text font-extrabold">Us</span>
      </h1>

      <p
        class="text-base md:text-xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed"
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="200"
      >
        Have questions, ideas, or want to collaborate? We'd love to hear from
        you. Reach out using the options below or visit us at our campus.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 relative">
    <div class="absolute inset-0 dot-grid opacity-20"></div>

    <div class="container mx-auto px-6 max-w-5xl relative z-10">
      <!-- Info Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <!-- Email -->
        <a
          href={`mailto:${contactInfo.email}`}
          class="group relative block h-full"
          data-aos="fade-up"
          data-aos-delay="0"
        >
          <div
            class="glass-card p-8 rounded-2xl border-t-2 border-teal-500 hover:-translate-y-1 transition-all duration-300 h-full flex items-start"
          >
            <div
              class="w-14 h-14 bg-teal-500/10 rounded-xl flex items-center justify-center mr-6 shrink-0 group-hover:scale-110 group-hover:bg-teal-500/20 transition-all duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6 text-teal-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <h3
                class="text-xl font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors"
              >
                Email Us
              </h3>
              <p class="text-slate-400 text-sm mb-3">
                For general inquiries, collaborations, and sponsorship
                opportunities.
              </p>
              <p class="text-cyan-400 font-semibold text-lg">
                {contactInfo.email}
              </p>
            </div>
          </div>
        </a>

        <!-- Location -->
        <div
          class="group relative block h-full"
          data-aos="fade-up"
          data-aos-delay="120"
        >
          <div
            class="glass-card p-8 rounded-2xl border-t-2 border-blue-500 hover:-translate-y-1 transition-all duration-300 h-full flex items-start"
          >
            <div
              class="w-14 h-14 bg-blue-500/10 rounded-xl flex items-center justify-center mr-6 shrink-0"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6 text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-2">Visit Us</h3>
              <p class="text-slate-400 leading-relaxed">
                {contactInfo.address.line1},<br />
                {contactInfo.address.line2},<br />
                {contactInfo.address.state}, {contactInfo.address.country} - {contactInfo.address.pincode}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Google Map -->
      <div
        class="relative h-[450px] w-full rounded-2xl overflow-hidden glass-card shadow-2xl group"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div
          class="absolute inset-0 pointer-events-none z-10 border border-white/5 rounded-2xl"
        ></div>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5031.222861355563!2d75.23167867601698!3d12.24347803042137!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ba465c310dea69b%3A0xe1985dae01d5292!2sCoE%20Trikaripur!5e1!3m2!1sen!2sin!4v1751959332372!5m2!1sen!2sin"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="grayscale hover:grayscale-0 transition-all duration-700 opacity-70 hover:opacity-100"
        ></iframe>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
